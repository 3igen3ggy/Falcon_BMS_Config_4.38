                pe[i][6] = pad_string("Target:", 15)
                i = i + 1
              elseif (n % 2 == 0) then
                pe[i][1] = pad_string(string.sub(line, 31, 45), 15)  -- flight number
                pe[i][2] = pad_string(string.sub(line, 61, 75), 15)  -- role
                pe[i][3] = pad_string(string.sub(line, 91, 105), 15) -- aircraft
              else
                pe[i][4] = pad_string(string.sub(line, 6, 20), 15)   -- take off
                pe[i][5] = pad_string(string.sub(line, 37, 51), 15)  -- push
                pe[i][6] = pad_string(string.sub(line, 66, 80), 15)  -- target
                i = i + 1
              end
              n = n + 1
              if i &gt; 6 then break end
            end
            if is_section(line, package_section) then section_found = true end
          end
        end

        -- format mission overview
        function format_mo_section()
          local s = "Mission Overview:" .. new_line .. new_line
          for i = 1, 5 do
            s = s .. mo[i] .. new_line
          end
          return s
        end

        -- format pilot roster section
        function format_pr_section()
          local s = divider .. new_line
          for j = 1, 5 do
            for i = 1, 3 do
              if i == 3 then
                s = s .. pr[i][j]
              else
                s = s .. pr[i][j] .. " | "
              end
            end
            s = s .. new_line .. divider .. new_line
          end
          return s
        end

        -- format package elements section
        function format_pe_section()
          local s = divider .. new_line
          for j = 1, 6 do
            for i = 1, 3 do
              if i == 3 then
                s = s .. pe[i][j]
              else
                s = s .. pe[i][j] .. " | "
              end
            end
            s = s .. new_line .. divider .. new_line
          end
          return s
        end

        -- initiate the functions above
        get_mo_section(input_file)
        get_pr_section(input_file)
        get_pe_section(input_file)
        mission_overview = format_mo_section()
        pilot_roster = format_pr_section()
        package_elements = format_pe_section()
        complete_page = mission_overview .. new_line .. pilot_roster .. new_line .. package_elements

        return complete_page
      </LuaScript>
    </Binding>
