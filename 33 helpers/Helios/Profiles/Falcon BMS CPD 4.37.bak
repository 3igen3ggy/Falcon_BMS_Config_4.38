    <Binding BypassCascadingTriggers="False">
      <Trigger Source="Visual;Monitor 2.Panel CENTER PEDESTAL DISPLAY.Panel PLAN.Button CPD PLAN UPDATE;Helios.Base.PushButton;Button CPD PLAN UPDATE" Name="pushed" />
      <Action Target="Visual;Monitor 2.Panel CENTER PEDESTAL DISPLAY.Panel PLAN.Panel MISSION 2.TextDisplay MISSION 2;Helios.Base.TextDisplay;TextDisplay MISSION 2" Name="set.TextDisplay" />
      <LuaScript>
        input_file = "C:\\Bin\\Briefing\\Briefing.txt"
        mission_section = "Mission Overview:"
        situation_section = "Situation:"
        pilot_section = "Pilot Roster:"
        package_section = "Package Elements:"
        threat_section = "Threat Analysis:"
        new_line = "\n"
        divider = string.rep("-", 51)

        mo = {}
        pr = {}

        for i = 1, 6 do     -- i = pilot roster columns
          pr[i] = {}
          for j = 1, 5 do   -- j = pilot roster rows
            pr[i][j] = string.rep(" ", 15)
          end
        end

        pe = {}

        for i = 1, 6 do     -- i = package elements columns
          pe[i] = {}
          for j = 1, 6 do   -- j = package elements rows
            pe[i][j] = string.rep(" ", 15)
          end
        end

        -- if file exists
        function file_exists(filename)
          local f = io.open(filename, "rb")
          if f then f:close() end
          return f ~= nil
        end

        if not file_exists(input_file) then return "" end

        -- is section name found
        function is_section(s, str)
          i, j = string.find(s, '^' .. str)
          return j ~= nil
        end

        -- pad string to given length
        function pad_string(str, len)
          str = string.gsub(str, '^%s*(.-)%s*$', '%1')
          str = str .. string.rep(" ", len - string.len(str))
          return str
        end

        -- get mission overview section from briefing
        function get_mo_section(filename)
          local section_found = false
          local i = 1
          for line in io.lines(filename) do
            if is_section(line, situation_section) then break end
            if section_found then
              line = line:gsub("%(", "")
              line = line:gsub("%)", "")
              if i == 1 then
                mo[i] = string.sub(line, 1, 52)
              else
                mo[i] = pad_string(string.sub(line, 1, 18), 18) .. string.sub(line, 31, 64)
              end
              i = i + 1
              if i &gt; 5 then break end
            end
            if is_section(line, mission_section) then section_found = true end
          end
        end

        -- get pilot roster section from briefing
        function get_pr_section(filename)
          local section_found = false
          local i = 1
          for line in io.lines(filename) do
            if is_section(line, package_section) then break end
            if section_found then
              if i == 1 then
                pr[i][1] = pad_string("Callsign:", 15)
                pr[i][2] = pad_string("Flt Lead:", 15)
                pr[i][3] = pad_string("Wing Two:", 15)
                pr[i][4] = pad_string("Elem Lead:", 15)
                pr[i][5] = pad_string("Elem Two:", 15)
              else
                pr[i][1] = pad_string(string.sub(line, 1, 15), 15)
                pr[i][2] = pad_string(string.sub(line, 31, 45), 15)
                pr[i][3] = pad_string(string.sub(line, 61, 75), 15)
                pr[i][4] = pad_string(string.sub(line, 91, 105), 15)
                pr[i][5] = pad_string(string.sub(line, 121, 135), 15)
              end
              i = i + 1
              if i &gt; 6 then break end
            end
            if is_section(line, pilot_section) then section_found = true end
          end
        end

        -- get package elements section from briefing
        function get_pe_section(filename)
          local section_found = false
          local i = 1
          local n = 1
          for line in io.lines(filename) do
            if is_section(line, threat_section) then break end
            if section_found then
              if n == 1 then
                pe[i][1] = pad_string("Flt #:", 15)
                pe[i][2] = pad_string("Role:", 15)
                pe[i][3] = pad_string("Aircraft:", 15)
                pe[i][4] = pad_string("Take Off:", 15)
                pe[i][5] = pad_string("Push:", 15)
                pe[i][6] = pad_string("Target:", 15)
                i = i + 1
              elseif (n % 2 == 0) then
                pe[i][1] = pad_string(string.sub(line, 31, 45), 15)  -- flight number
                pe[i][2] = pad_string(string.sub(line, 61, 75), 15)  -- role
                pe[i][3] = pad_string(string.sub(line, 91, 105), 15) -- aircraft
              else
                pe[i][4] = pad_string(string.sub(line, 6, 20), 15)   -- take off
                pe[i][5] = pad_string(string.sub(line, 37, 51), 15)  -- push
                pe[i][6] = pad_string(string.sub(line, 66, 80), 15)  -- target
                i = i + 1
              end
              n = n + 1
              if i &gt; 6 then break end
            end
            if is_section(line, package_section) then section_found = true end
          end
        end

        -- format mission overview
        function format_mo_section()
          local s = "Mission Overview:" .. new_line .. new_line
          for i = 1, 5 do
            s = s .. mo[i] .. new_line
          end
          return s
        end

        -- format pilot roster section
        function format_pr_section()
          local s = divider .. new_line
          for j = 1, 5 do
            for i = 4, 6 do
              if i == 6 then
                s = s .. pr[i][j]
              else
                s = s .. pr[i][j] .. " | "
              end
            end
            s = s .. new_line .. divider .. new_line
          end
          return s
        end

        -- format package elements section
        function format_pe_section()
          local s = divider .. new_line
          for j = 1, 6 do
            for i = 4, 6 do
              if i == 6 then
                s = s .. pe[i][j]
              else
                s = s .. pe[i][j] .. " | "
              end
            end
            s = s .. new_line .. divider .. new_line
          end
          return s
        end

        -- initiate the functions above
        get_mo_section(input_file)
        get_pr_section(input_file)
        get_pe_section(input_file)
        mission_overview = format_mo_section()
        pilot_roster = format_pr_section()
        package_elements = format_pe_section()
        complete_page = mission_overview .. new_line .. pilot_roster .. new_line .. package_elements

        return complete_page
      </LuaScript>
    </Binding>
    <Binding BypassCascadingTriggers="False">
