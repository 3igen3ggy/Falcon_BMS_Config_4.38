    <Binding BypassCascadingTriggers="False">
      <Trigger Source="Visual;Monitor 2.Panel CENTER PEDESTAL DISPLAY.Panel PLAN.Panel MISSION 1.Button MISSION 1;Helios.Base.PushButton;Button MISSION 1" Name="pushed" />
