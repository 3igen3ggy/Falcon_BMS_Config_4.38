      <Action Target="Visual;Monitor 2.Panel VERSION CHECK;Helios.Panel;Panel VERSION CHECK" Name="set.hidden" />
      <StaticValue>true</StaticValue>
    </Binding>
    <Binding BypassCascadingTriggers="False">
      <Trigger Source="Visual;Monitor 2.Panel VERSION CHECK.Rotary VERSION CHECK;Helios.Base.RotarySwitch;Rotary VERSION CHECK" Name="position 3.entered" />
      <Action Target="Visual;Monitor 2.Panel VERSION CHECK.Panel VERSION ERROR;Helios.Panel;Panel VERSION ERROR" Name="set.hidden" />
      <StaticValue>false</StaticValue>
    </Binding>
    <Binding BypassCascadingTriggers="False">
      <Trigger Source="Visual;Monitor 2.Panel VERSION CHECK.Rotary VERSION CHECK;Helios.Base.RotarySwitch;Rotary VERSION CHECK" Name="position 3.entered" />
      <Action Target="Visual;Monitor 2.Panel VERSION CHECK.Panel VERSION ERROR.Panel VERSION ERROR TEXT.TextDisplay VERSION ERROR TEXT;Helios.Base.TextDisplay;TextDisplay VERSION ERROR TEXT" Name="set.TextDisplay" />
      <LuaScript>      
        newline = string.char(10)

        s = newline
        s = s .. "   The reason you are seeing this message is either:" .. newline .. newline
        s = s .. "   1. The Helios Version is an earlier release than that required for this profile." .. newline .. newline
        s = s .. "   2. The profile was opened and saved in an earlier version of Helios thus removing various sections." .. newline .. newline .. newline
        s = s .. "   To resolve this carry out the following:" .. newline .. newline
        s = s .. "   1. Install the latest version of Helios if not already installed." .. newline .. newline
        s = s .. "   2. Reinstall the profile file from the Profile Setup download and perform Reset Monitors again." .. newline

        return s
      </LuaScript>
    </Binding>
    <Binding BypassCascadingTriggers="False">
      <Trigger Source="Visual;Monitor 2.Panel VERSION CHECK.MemoryWire VERSION CHECK;Helios.Base.MemoryWire;MemoryWire VERSION CHECK" Name="Text Signal.changed" />
      <Action Target="Visual;Monitor 2.Panel VERSION CHECK.Rotary VERSION CHECK;Helios.Base.RotarySwitch;Rotary VERSION CHECK" Name="set.position" />
      <LuaScript>      
        TargetValue = "1.6.6100.0004"

        TargetVersion = TargetValue:gsub("%.", "")
        TargetVersion = tonumber(TargetVersion)

        RunningVersion = RunningVersion or nil

        if TriggerValue == "VERSIONCHECK" then
          if RunningVersion == nil then
            return 3
          else
            return 2
          end
        else
          RunningVersion = TriggerValue:gsub("%.", "")
          RunningVersion = tonumber(RunningVersion)
          if RunningVersion &gt;= TargetVersion then
            return 2
          else
            return 3
          end
        end
      </LuaScript>
    </Binding>
    <Binding BypassCascadingTriggers="False">
