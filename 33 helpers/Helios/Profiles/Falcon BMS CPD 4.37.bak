    <Binding BypassCascadingTriggers="False">
      <Trigger Source="Visual;Monitor 2.Panel CENTER PEDESTAL DISPLAY.Panel PLAN.Button CPD PLAN UPDATE;Helios.Base.PushButton;Button CPD PLAN UPDATE" Name="pushed" />
      <Action Target="Visual;Monitor 2.Panel CENTER PEDESTAL DISPLAY.Panel PLAN.Panel COMMS 2.TextDisplay COMMS 2;Helios.Base.TextDisplay;TextDisplay COMMS 2" Name="set.TextDisplay" />
      <LuaScript>
        input_file = "C:\\Bin\\Briefing\\Briefing.txt"
        comm_section = "Comm Ladder:"
        iff_section = "Iff"
        general_section = "GENERAL:"
        dep_atis_section = "Dep Atis"
        arr_atis_section = "Arr Atis"
        alt_atis_section = "Alt Atis"
        guard_section = "Guard:"
        new_line = "\n"
        divider = string.rep("-", 55)

        -- if file exists
        function file_exists(filename)
          local f = io.open(filename, "rb")
          if f then f:close() end
          return f ~= nil
        end

        -- is section name found
        function is_section(s, str)
          i, j = string.find(s, '^' .. str)
          return j ~= nil
        end

        -- pad string to given length
        function pad_string(str, len)
          str = string.gsub(str, '^%s*(.-)%s*$', '%1')
          str = str .. string.rep(" ", len - string.len(str))
          return str
        end

        s = ""

        -- get section from briefing
        function get_section(filename)
          local section_found = false
          local dep_atis_found = false
          local i = 0
          if not file_exists(filename) then return end
          for line in io.lines(filename) do
            if is_section(line, iff_section) or is_section(line, general_section) then break end
              if section_found then
                i = i + 1
                s1 = pad_string(string.sub(line, 1, 15), 16)
                s2 = pad_string(string.sub(line, 31, 48), 19)
                s3 = pad_string(string.sub(line, 61, 76), 17)
                s4 = pad_string(string.sub(line, 91, 106), 17)
                s5 = s2 .. s3 .. s4
                if i == 1 or i == 2 then
                  s = s .. s5 .. new_line
                else
                  if is_section(line, dep_atis_section) then dep_atis_found = true end 
                  if dep_atis_found then
                    if is_section(line, dep_atis_section) or is_section(line, arr_atis_section) or is_section(line, alt_atis_section) then
                      s = s .. divider .. new_line
                    end
                    s = s .. "# " .. s1 .. new_line .. s5 .. new_line
                  end
                end
              end
            if is_section(line, comm_section) then section_found = true end
          end
          s = s .. divider
        end

        -- initiate the functions above
        get_section(input_file)

        return s
      </LuaScript>
    </Binding>
