  <Interfaces>
    <Interface TypeIdentifier="Helios.Base.Keyboard" Name="Keyboard">
      <KeyDelay>30</KeyDelay>
    </Interface>
    <Interface TypeIdentifier="Helios.Base.ProfileInterface" Name="Profile" />
    <Interface TypeIdentifier="Helios.Falcon.Interface" Name="Falcon">
      <FalconType>BMS</FalconType>
      <FalconVersion>Falcon BMS 4.37</FalconVersion>
      <KeyFile>C:\Bin\KeyFile\BMS - CPD Addon.key</KeyFile>
      <FocusAssist>False</FocusAssist>
      <ForceKeyFile>False</ForceKeyFile>
      <TextureRefreshRate_30>False</TextureRefreshRate_30>
      <TextureRefreshRate_60>False</TextureRefreshRate_60>
      <TextureRefreshRate_90>True</TextureRefreshRate_90>
      <RTT Networked="false" Enabled="false" xmlns="http://Helios.local/HeliosFalcon/Interfaces/RTT/RttConfigGenerator">
        <Network />
        <Local />
        <ProcessControl />
      </RTT>
    </Interface>
    <Interface TypeIdentifier="HeliosProcessControl.ProcessControlInterface" Name="Process Control">
      <Configuration xmlns="http://Helios.local/HeliosProcessControl/Interfaces/ProcessControl/Configuration" />
    </Interface>
    <Interface TypeIdentifier="Helios.Base.HeliosInformation" Name="Helios Information" />
  </Interfaces>
