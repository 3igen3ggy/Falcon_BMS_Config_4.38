    <Binding BypassCascadingTriggers="False">
      <Trigger Source="Visual;Monitor 2.Panel CENTER PEDESTAL DISPLAY.Panel PLAN.Button CPD PLAN UPDATE;Helios.Base.PushButton;Button CPD PLAN UPDATE" Name="pushed" />
      <Action Target="Visual;Monitor 2.Panel CENTER PEDESTAL DISPLAY.Panel PLAN.Panel STEERPOINTS 2.TextDisplay STEERPOINTS P2;Helios.Base.TextDisplay;TextDisplay STEERPOINTS P2" Name="set.TextDisplay" />
      <LuaScript>
        input_file = "C:\\Bin\\Briefing\\Briefing.txt"
        steerpoints_section = "Steerpoints:"
        comm_section = "Comm Ladder:"
        new_line = "\n"
        divider = string.rep("-", 53)

        -- if file exists
        function file_exists(filename)
          local f = io.open(filename, "rb")
          if f then f:close() end
          return f ~= nil
        end

        -- is section name found
        function is_section(s, str)
          i, j = string.find(s, '^' .. str)
          return j ~= nil
        end

        s = ""

        -- get section from briefing
        function get_section(filename)
          local section_found = false
          local i = -1
          if not file_exists(filename) then return end
          for line in io.lines(filename) do
            if is_section(line, comm_section) then break end
            if section_found then
              i = i + 1
              if i == 0 then
                s = "#: Desc:      Time:     Dist: Hdg: Ias: Alt:  Action:" .. new_line .. divider .. new_line
              end
              if i &gt; 11 then
                s1 = string.sub(line, 31, 40)
                s2 = string.sub(line, 60, 70)
                s3 = string.sub(line, 121, 126)
                s4 = string.sub(line, 181, 185)
                s5 = string.sub(line, 241, 245)
                s6 = string.sub(line, 301, 306)
                s7 = string.sub(line, 331, 338)
                s8 = string.sub(line, 391, 440)
                h, j = string.find(s7, " ")
                s7 = string.sub(s7, 1, j)
                s8 = s8:gsub("%(", "")
                s8 = s8:gsub("%)", "")
                s = s .. string.format("%02d", i) .. " " .. s1 .. s2 .. s3 .. s4 .. s5 .. s6 .. s7 .. new_line
                s = s  .. "   " .. s8 .. new_line .. divider .. new_line
              end
            end
            if i == 22 then break end
            if is_section(line, steerpoints_section) then section_found = true end
          end
        end

        -- initiate the functions above
        get_section(input_file)

        return s
      </LuaScript>
    </Binding>
