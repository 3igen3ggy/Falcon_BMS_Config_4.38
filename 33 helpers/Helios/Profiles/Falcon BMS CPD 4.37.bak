    <Binding BypassCascadingTriggers="False">
      <Trigger Source="Interface;;Helios.Falcon.Interface;Falcon" Name="Runtime.Flying.changed" />
      <Action Target="Visual;Monitor 2.Panel CENTER PEDESTAL DISPLAY.Button AUTO RESET;Helios.Base.PushButton;Button AUTO RESET" Name="set.physical state" />
      <LuaScript>
        lastValue = lastValue or false
        value = false
        if TriggerValue ~= lastValue then
          value = not TriggerValue
        end
        lastValue = TriggerValue
        return value
      </LuaScript>
    </Binding>
    <Binding BypassCascadingTriggers="False">
