      <Action Target="Visual;Monitor 2.Panel VERSION CHECK.MemoryWire VERSION CHECK;Helios.Base.MemoryWire;MemoryWire VERSION CHECK" Name="set.Text Signal" />
      <StaticValue>VERSIONCHECK</StaticValue>
    </Binding>
