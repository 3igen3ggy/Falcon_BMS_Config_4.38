      <Action Target="Visual;Monitor 2.Panel CENTER PEDESTAL DISPLAY.Panel DATA.Label MAXIMUM G FORCE;Helios.Base.Text;Label MAXIMUM G FORCE" Name="set.Text" />
      <LuaScript>      
        g_force = math.abs(math.floor(TriggerValue * 10))
        gmax = gmax or 0
        if g_force &gt; gmax then
          gmax = g_force
        end
        return string.format("%.1f", gmax/10)
      </LuaScript>
    </Binding>
