    <Binding BypassCascadingTriggers="False">
      <Trigger Source="Interface;;Helios.Falcon.Interface;Falcon" Name="Fuel.external fuel.changed" />
      <Action Target="Visual;Monitor 2.Panel CENTER PEDESTAL DISPLAY.Panel FUEL.Label FUEL EXTERNAL;Helios.Base.Text;Label FUEL EXTERNAL" Name="set.Text" />
      <LuaScript>
